{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Ninja"
        },
        {
            "name": "debug",
            "inherits": "default",
            "displayName": "Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "inherits": "default",
            "displayName": "Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "dist",
            "inherits": "default",
            "displayName": "Distribution",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "android-default",
            "hidden": true,
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
                "ANDROID_PLATFORM": "android-24"
            }
        },
        {
            "name": "android-arm64",
            "inherits": "android-default",
            "displayName": "Android arm64-v8a (Release)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ANDROID_ABI": "arm64-v8a"
            }
        },
        {
            "name": "android-arm64-debug",
            "inherits": "android-default",
            "displayName": "Android arm64-v8a (Debug)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ANDROID_ABI": "arm64-v8a"
            }
        },
        {
            "name": "android-arm32",
            "inherits": "android-default",
            "displayName": "Android armeabi-v7a (Release)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ANDROID_ABI": "armeabi-v7a"
            }
        },
        {
            "name": "android-arm32-debug",
            "inherits": "android-default",
            "displayName": "Android armeabi-v7a (Debug)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ANDROID_ABI": "armeabi-v7a"
            }
        },
        {
            "name": "android-x86_64",
            "inherits": "android-default",
            "displayName": "Android x86_64 (Release)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ANDROID_ABI": "x86_64"
            }
        },
        {
            "name": "android-x86_64-debug",
            "inherits": "android-default",
            "displayName": "Android x86_64 (Debug)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ANDROID_ABI": "x86_64"
            }
        },
        {
            "name": "ios",
            "displayName": "iOS (Release)",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Xcode",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0"
            }
        },
        {
            "name": "ios-debug",
            "displayName": "iOS (Debug)",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "generator": "Xcode",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "dist",
            "configurePreset": "dist"
        },
        {
            "name": "android-arm64",
            "configurePreset": "android-arm64"
        },
        {
            "name": "android-arm64-debug",
            "configurePreset": "android-arm64-debug"
        },
        {
            "name": "android-arm32",
            "configurePreset": "android-arm32"
        },
        {
            "name": "android-arm32-debug",
            "configurePreset": "android-arm32-debug"
        },
        {
            "name": "android-x86_64",
            "configurePreset": "android-x86_64"
        },
        {
            "name": "android-x86_64-debug",
            "configurePreset": "android-x86_64-debug"
        },
        {
            "name": "ios",
            "configurePreset": "ios",
            "configuration": "Release"
        },
        {
            "name": "ios-debug",
            "configurePreset": "ios-debug",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "output": { "outputOnFailure": true }
        }
    ]
}
